    <script>
        let currentSlideIndex = 0;
        const track = document.getElementById('videoTrack');
        const dots = document.querySelectorAll('.dot');
        const totalSlides = 2;

        function updateSliderPosition() {
            track.style.transform = `translateX(-${currentSlideIndex * 50}%)`;
            
            // Toggle active pagination highlights
            dots.forEach((dot, index) => {
                if(index === currentSlideIndex) {
                    dot.classList.add('active');
                } else {
                    dot.classList.remove('active');
                }
            });

            // Post command structure to pause inactive iframe video pipelines via YouTube JS API
            const p1 = document.getElementById('player1').contentWindow;
            const p2 = document.getElementById('player2').contentWindow;
            
            if (currentSlideIndex === 0) {
                p2.postMessage('{"event":"command","func":"pauseVideo","args":""}', '*');
            } else {
                p1.postMessage('{"event":"command","func":"pauseVideo","args":""}', '*');
            }
        }

        function moveSlide(direction) {
            currentSlideIndex += direction;
            if (currentSlideIndex >= totalSlides) currentSlideIndex = 0;
            if (currentSlideIndex < 0) currentSlideIndex = totalSlides - 1;
            updateSliderPosition();
        }

        function goToSlide(index) {
            currentSlideIndex = index;
            updateSliderPosition();
        }
    </script>

