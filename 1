            background-attachment: fixed;
            background-repeat: repeat;
            color: var(--espresso);
            font-family: var(--font-sans);
            font-size: 16px;
            line-height: 1.7;
            overflow-x: hidden;
        }

        h1, h2, h3, h4 {
            font-family: var(--font-serif);
            font-weight: 300;
            letter-spacing: 0.06em;
        }

        a {
            color: var(--espresso);
            text-decoration: none;
            transition: all 0.3s ease;
        }

        /* Floating Navigation */
        nav {
            background-color: rgba(248, 245, 241, 0.92);
            backdrop-filter: blur(5px);
            border-bottom: 1px solid rgba(216, 198, 181, 0.4);
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.5rem 10%;
        }

        .logo {
            font-family: var(--font-serif);
            font-size: 1.6rem;
            font-weight: 400;
            letter-spacing: 0.15em;
        }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 2.5rem;
        }

        .nav-links a {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.15em;
        }

        .nav-links a:hover {
            color: var(--champagne-gold);
        }

        /* Hero / Welcome Section */
        .hero {
            padding: 15rem 10% 10rem 10%;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .hero h1 {
            font-size: 3.8rem;
            margin-bottom: 1.5rem;
            line-height: 1.2;
            font-style: italic;
        }

        .hero p {
            font-family: var(--font-sans);
            font-weight: 300;
            font-size: 1.1rem;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            color: var(--taupe);
            max-width: 700px;
            margin-bottom: 3rem;
        }

        /* Luxury Call to Action Buttons */
        .cta-button {
            display: inline-block;
            background-color: var(--olive);
            color: var(--warm-ivory);
            padding: 1.1rem 2.8rem;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 0.2em;
            transition: all 0.4s ease;
            border: 1px solid var(--olive);
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(110, 120, 102, 0.15);
        }

        .cta-button:hover {
            background-color: transparent;
            color: var(--espresso);
            border: 1px solid var(--taupe);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.05);
        }

        /* Core Layout Components */
        section {
            padding: 7rem 10%;
            max-width: 1200px;
            margin: 0 auto;
        }

        .section-title {
            text-align: center;
            font-size: 2.6rem;
            margin-bottom: 0.5rem;
            font-style: italic;
        }

        .section-subtitle {
            text-align: center;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            color: var(--taupe);
            margin-bottom: 4rem;
        }

        /* Showcase Custom Swiper Layout */
        .swiper-wrapper-container {
            position: relative;
            width: 100%;
            max-width: 460px; /* Slightly widened to accommodate navigation handles elegantly */
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .video-slider {
            width: 100%;
            max-width: 380px;
            overflow: hidden;
            position: relative;
        }

        .video-track {
            display: flex;
            transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
            width: 200%; /* Two slides total */
        }

        .video-slide {
            width: 50%; /* Each slide takes exactly half of the 200% width track */
            flex-shrink: 0;
            padding: 0 5px;
        }

        /* Responsive Vertical Shorts Video Frame */
        .video-container {
            position: relative;
            width: 100%;
            box-shadow: 0 20px 45px rgba(62, 51, 44, 0.08);
            border: 14px solid var(--soft-linen);
            background-color: var(--soft-linen);
        }

        .video-ratio {
            position: relative;
            padding-bottom: 177.77%; /* Vertical 9:16 Aspect Ratio */
            height: 0;
            overflow: hidden;
        }

        .video-ratio iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
        }

        /* Micro Swiper Navigation UI Elements */
        .swiper-btn {
            background: none;
            border: none;
            font-family: var(--font-serif);
            font-size: 2.2rem;
            color: var(--taupe);
            cursor: pointer;
            padding: 0 10px;
            user-select: none;
            transition: color 0.3s ease;
            position: absolute;
            z-index: 10;
        }
        
        .swiper-btn:hover {
            color: var(--espresso);
        }

        .swiper-btn.prev { left: -10px; }
        .swiper-btn.next { right: -10px; }

        .swiper-dots {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-top: 1.5rem;
        }

        .dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background-color: var(--sandstone);
            cursor: pointer;
            transition: background-color 0.3s ease, transform 0.3s ease;
        }

        .dot.active {
            background-color: var(--espresso);
            transform: scale(1.2);
        }

        /* Wedding Offerings / Lineups Grid */
        .intro-text {
            text-align: center;
            max-width: 750px;
            margin: 0 auto 5rem auto;
            font-size: 1.25rem;
            font-family: var(--font-serif);
            font-style: italic;
            color: var(--espresso);
            line-height: 1.8;
        }

        .lineups {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
        }

        .lineup-card {
            background-color: rgba(248, 245, 241, 0.85);
            padding: 3.5rem 2.5rem;
            border: 1px solid var(--sandstone);
            text-align: center;
            backdrop-filter: blur(3px);
            position: relative;
        }

        .lineup-card::before {
            content: '';
            position: absolute;
            top: 10px; left: 10px; right: 10px; bottom: 10px;
            border: 1px solid rgba(201, 179, 138, 0.3);
            pointer-events: none;
        }

        .lineup-card h3 {
            font-size: 2rem;
            margin-bottom: 1.2rem;
            color: var(--espresso);
        }

        .lineup-card p {
            font-size: 0.95rem;
            color: var(--taupe);
            font-weight: 300;
        }

        /* Call To Action Frame */
        .contact-section {
            text-align: center;
            padding: 9rem 10%;
            max-width: 100%;
            background: linear-gradient(to bottom, transparent, var(--soft-linen));
        }

        .contact-section p {
            max-width: 600px;
            margin: 0 auto 3rem auto;
            font-size: 1.1rem;
            font-family: var(--font-serif);
            font-style: italic;
        }

        /* Footer */
        footer {
            background-color: var(--espresso);
            color: var(--warm-ivory);
            text-align: center;
            padding: 3.5rem 10%;
            font-size: 0.8rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        footer p {
            color: var(--sandstone);
        }

        /* Mobile Adjustments */
        @media (max-width: 768px) {
            nav { padding: 1rem 5%; flex-direction: column; gap: 0.8rem; }
            .nav-links { gap: 1.5rem; }
            .hero { padding: 15rem 5% 7rem 5%; }
            .hero h1 { font-size: 2.5rem; }
            section { padding: 5rem 5%; }
            .lineups { grid-template-columns: 1fr; gap: 2.5rem; }
            .video-container { border: 6px solid var(--soft-linen); }
            .swiper-wrapper-container { max-width: 100%; }
            .swiper-btn.prev { left: -5px; }
            .swiper-btn.next { right: -5px; }
        }
    </style>
</head>
<body>

    <nav>
